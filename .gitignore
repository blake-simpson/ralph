# Build output
dist/
/belmont

# Embedded content (copied by build script, cleaned up after)
cmd/belmont/skills/
cmd/belmont/agents/

# Generated skill folders (Phase 2: produced by scripts/generate-skills.sh from
# _src/ + _partials/ — not committed, regenerated on `go generate ./...` or
# auto-regenerated by source-mode `belmont install`).
skills/belmont/*/
!skills/belmont/_src/
!skills/belmont/_partials/

# Local belmont install artifacts
.belmont/bin/
.belmont/cache/

# Local Claude settings
.claude/
